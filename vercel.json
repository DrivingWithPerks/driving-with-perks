{
  "buildCommand": "pnpm install && pnpm build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/handler.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/handler.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
